{
  "name": "@klar/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:debug": "nest start --watch --debug 0.0.0.0:9229",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "keys:generate": "tsx scripts/generate-keys.ts",
    "prisma:generate": "prisma generate --schema=../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "prisma:seed": "tsx ../../prisma/seed.ts",
    "prisma:seed:defaults": "tsx ../../prisma/seed-defaults.ts",
    "prisma:reset": "prisma migrate reset --schema=../../prisma/schema.prisma --force && tsx ../../prisma/seed.ts",
    "prisma:studio": "prisma studio --schema=../../prisma/schema.prisma",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@klar/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.5",
    "handlebars": "^4.7.0",
    "iconv-lite": "^0.7.2",
    "jsonwebtoken": "^9.0.3",
    "lib-fints": "^1.4.7",
    "nestjs-pino": "^4.0.0",
    "nodemailer": "^8.0.7",
    "openid-client": "^5.7.1",
    "otpauth": "^9.5.1",
    "papaparse": "^5.5.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-http": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@swc/core": "^1.15.33",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/passport-local": "^1.0.0",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  }
}
