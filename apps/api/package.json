{
  "name": "@klar/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:debug": "nest start --watch --debug 0.0.0.0:9229",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "keys:generate": "tsx scripts/generate-keys.ts",
    "prisma:migrate": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "prisma:seed": "tsx ../../prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --schema=../../prisma/schema.prisma --force && tsx ../../prisma/seed.ts",
    "prisma:studio": "prisma studio --schema=../../prisma/schema.prisma",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@klar/shared": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "argon2": "^0.43.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.0.0",
    "handlebars": "^4.7.0",
    "nestjs-pino": "^4.0.0",
    "nodemailer": "^6.0.0",
    "openid-client": "^5.7.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino-http": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@swc/core": "^1.15.32",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.0.0",
    "@types/passport-local": "^1.0.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  }
}
