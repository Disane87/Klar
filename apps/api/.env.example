DATABASE_URL=postgresql://klar:klar@localhost:5432/klar
DATABASE_TEST_URL=postgresql://klar:klar@localhost:5432/klar_test
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PORT=3000
NODE_ENV=development
REGISTRATION_ENABLED=true
FRONTEND_URL=http://localhost:4200

# OIDC / SSO (optional — any OpenID Connect compliant provider)
OIDC_ENABLED=false
OIDC_PROVIDER_NAME=sso
OIDC_ISSUER_URL=https://id.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/oidc/callback
OIDC_SCOPES=openid email profile
# Group mapping (optional — leave empty to disable)
OIDC_REQUIRED_GROUP=
OIDC_ADMIN_GROUP=
OIDC_AUTO_JOIN_HOUSEHOLD_ID=

# ─── FinTS (Phase 14a Bank-Sync) ──────────────────────────────────────────────
# 32-byte hex (openssl rand -hex 32). AES-256-GCM master key for sealing PINs +
# lib-fints session state. BACK UP SEPARATELY from the database — without this
# key, all stored bank connections are unrecoverable.
FINTS_MASTER_KEY=
# PSD2 Strong-Customer-Authentication window in days. Reauth watcher pre-warns
# 7 days before expiry; default 89 stays one day under the bank's 90-day limit.
FINTS_SCA_WINDOW_DAYS=89
# Comma-separated upstream URLs for the BLZ → FinTS-server-URL registry.
FINTS_BLZ_SOURCES=https://raw.githubusercontent.com/hbci4j/hbci4java/master/src/main/resources/blz.properties
# ZKA product registration. Replace with the real ID once registered.
# Product version is derived from the app's package.json (APP_VERSION).
FINTS_PRODUCT_ID=klar-dev
