<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ruleName}} — Klar</title>
</head>
<body style="margin:0;padding:0;background-color:#09090b;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#09090b;">
    <tr>
      <td align="center" style="padding:48px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:560px;">
          <tr>
            <td align="center" style="padding-bottom:32px;">
              <span style="font-size:24px;font-weight:700;letter-spacing:-0.5px;color:#f4f4f5;">Klar</span>
            </td>
          </tr>
          <tr>
            <td style="background-color:#18181b;border-radius:12px;border:1px solid #27272a;padding:32px;">
              <p style="margin:0 0 8px;font-size:11px;text-transform:uppercase;letter-spacing:0.14em;color:#a1a1aa;">Regel ausgelöst</p>
              <p style="margin:0 0 16px;font-size:20px;font-weight:600;color:#f4f4f5;line-height:1.3;">{{ruleName}}</p>
              {{#if body}}
              <p style="margin:0 0 16px;font-size:14px;color:#d4d4d8;line-height:1.5;">{{body}}</p>
              {{/if}}
              {{#if deepLinkUrl}}
              <p style="margin:24px 0 0;">
                <a href="{{deepLinkUrl}}" style="display:inline-block;background:#e4a76b;color:#18181b;text-decoration:none;font-weight:600;padding:10px 18px;border-radius:8px;font-size:14px;">In Klar öffnen</a>
              </p>
              {{/if}}
            </td>
          </tr>
          <tr>
            <td style="padding-top:24px;text-align:center;font-size:11px;color:#52525b;line-height:1.6;">
              Du erhältst diese E-Mail wegen deiner Regel „{{ruleName}}".<br />
              Anpassen unter <a href="{{settingsUrl}}" style="color:#71717a;">Einstellungen → Benachrichtigungen</a>.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
