// prisma/schema.prisma
// Klar — Datenmodell v1
// Alle Beträge in Cent (amountCents: Int, signed: positiv=Einnahme, negativ=Ausgabe)
// Alle Datumsfelder ohne Uhrzeit (@db.Date) um Timezone-Drift zu vermeiden

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AppRole {
  USER
  ADMIN
}

enum HouseholdRole {
  OWNER
  MEMBER
}

enum CategoryType {
  // Income types
  FIXED_INCOME // regelmäßiges Gehalt, fester Betrag
  VARIABLE_INCOME // Zinsen, Boni, Nebeneinkünfte (heute "INCOME")
  // Expense types
  FIXED_EXPENSE // Miete, Versicherung, Abo (heute pauschal "EXPENSE")
  VARIABLE_EXPENSE // Lebensmittel, Tanken, Restaurant
  // Savings / wealth building (kein "echter" Ausgabeposten)
  SAVINGS
  // Legacy types — bleiben erhalten für Bestandsdaten
  INCOME
  EXPENSE
}

enum RecurringFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  WEEKLY
  HALF_YEARLY
  CUSTOM_DAYS
}

enum Visibility {
  PRIVATE
  SHARED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum NotificationKind {
  CONTRACT_RENEWAL
  CONTRACT_PRICE_CHANGE
  RECURRING_DUE
  IMPORT_READY
  BUDGET_THRESHOLD
  MEMBER_INVITE
  SYSTEM
  // FinTS-Foundation (Phase 14a.7):
  FINTS_REAUTH_WARNING
  FINTS_REAUTH_REQUIRED
  FINTS_SYNC_FAILED
  FINTS_BALANCE_DRIFT
  FINTS_BLZ_REGISTRY_STALE
}

enum FixedCostCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  CUSTOM
}

// FinTS-Foundation (Phase 14a.1) — Konto als eigenständige Entität.
// Vorher hingen Transaktionen direkt am Household; mit FinTS bekommt jeder
// Eingangskanal (Bank-Konto, Bargeld-Wallet, CSV-Import-Topf) ein Account.
enum AccountType {
  fints // FinTS-synchronisiertes Bank-Konto, Bank-Felder readonly
  csv_only // Klassischer CSV-Import-Topf (Default für Bestand)
  cash // Bargeld/Wallet, alles manuell
  manual // Frei-Manuell ohne CSV/FinTS
}

// Quelle einer Transaction. Ergänzt das bestehende sourceImportId-Feld.
enum TxSource {
  manual
  csv
  fints
}

// FinTS-Verbindungs-Status (Phase 14a.3):
enum FintsConnectionStatus {
  SETUP // gerade eingerichtet, noch nie erfolgreich gesynct
  ACTIVE
  TAN_REQUIRED // ein laufender Run wartet auf TAN
  REAUTH_REQUIRED // 90-Tage-SCA abgelaufen oder Bank verlangt frische Auth
  DISABLED // User hat manuell deaktiviert
  ERROR // permanenter Fehler, manuelle Aktion nötig
}

enum FintsSyncStatus {
  RUNNING
  OK
  FAILED
  TAN_REQUIRED
  REAUTH_REQUIRED
  CANCELLED
}

enum FintsSyncTrigger {
  CRON
  MANUAL
  SETUP
}

enum FixedCostStatus {
  CANDIDATE // auto-detected, awaiting user review
  DETECTED // user reviewed but not yet confirmed
  CONFIRMED // user confirmed, counts as active fixed cost
  CANCELLED // ended (contract terminated, subscription stopped)
}

// Standing Orders (Daueraufträge) — Phase 14b
// Bank-side payment instruction, distinct from RecurringTransaction (budget concept).
// Bank ist Source of Truth für FINTS_DERIVED records — Bank-Felder sind dann gesperrt.

enum TransactionKind {
  STANDING_ORDER
  DIRECT_DEBIT
  TRANSFER
  CARD
  FEE
  OTHER
}

enum StandingOrderSource {
  FINTS_DERIVED
  MANUAL
}

enum StandingOrderFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  CUSTOM
  UNKNOWN
}

// ─────────────────────────────────────────────
// AUTH & USER
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique // IMMER lowercase gespeichert
  emailVerified Boolean   @default(false)
  displayName   String
  passwordHash  String? // null bei reinen OIDC-Usern
  appRole       AppRole   @default(USER)
  isDeleted     Boolean   @default(false) // soft-delete bei Account-Löschung
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  totpSecret    String? // Base32 encoded TOTP secret
  totpEnabled   Boolean   @default(false)
  avatarUrl     String? // base64 JPEG data URL (~15KB), stored directly in DB

  memberships           HouseholdMembership[]
  oidcIdentities        OidcIdentity[]
  refreshTokens         RefreshToken[]
  emailVerifications    EmailVerification[]
  recurringTransactions RecurringTransaction[]
  tempTokens            TempToken[]
  oauthAuthCodes        OAuthAuthCode[]
  oauthGrants           OAuthGrant[]
  oauthConsents         OAuthConsent[]
  notifications         Notification[]
  connectedApps         ConnectedApp[]
  ownedAccounts         Account[]              @relation("AccountOwner")
  fintsConnections      FintsConnection[]      @relation("FintsConnectionOwner")

  @@index([email])
  @@index([isDeleted])
}

// Ephemeral: E-Mail-Verifikations-Token (TTL: 24h)
// Cleanup-Job löscht abgelaufene Einträge.
model EmailVerification {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique // kryptografisch zufällig, 32 Bytes hex
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  inviteToken String? // optional InvitationLink token to consume after email verification

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OidcIdentity {
  id           String    @id @default(cuid())
  userId       String
  providerName String // z.B. "pocketid", "github"
  oidcSub      String // Subject-Claim vom IdP
  email        String // snapshot der E-Mail vom IdP zum Zeitpunkt des Logins
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerName, oidcSub])
  @@index([userId])
}

// Kurzlebig: State + PKCE für OIDC Authorization Code Flow
// TTL: 10 Minuten. Cleanup-Job löscht abgelaufene Einträge.
model OidcLoginState {
  id                 String   @id @default(cuid())
  providerName       String
  state              String   @unique
  codeVerifier       String // PKCE Code-Verifier
  redirectAfterLogin String? // optionaler Redirect nach erfolgreichem Login
  expiresAt          DateTime
  createdAt          DateTime @default(now())
}

// Kurzlebig: One-Time-Code für Token-Übergabe an SPA nach OIDC-Callback
// TTL: 60 Sekunden, single-use (usedAt wird gesetzt)
model OneTimeHandoverCode {
  id        String    @id @default(cuid())
  code      String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique // Argon2id-Hash des tatsächlichen Tokens
  expiresAt    DateTime
  revokedAt    DateTime? // null = noch gültig
  userAgent    String?
  ip           String?
  ipHash       String? // sha256(ip + secret) — für Sessions-UI ohne Plaintext-IP
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // für Cleanup
}

model TempToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique // Plain text (short-lived, 5 min)
  purpose   String // z.B. "totp_login"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────
// HAUSHALT & MITGLIEDER
// ─────────────────────────────────────────────

model Household {
  id        String   @id @default(cuid())
  name      String
  /**
   * Free-text household note shown in the Fixkosten right-rail Notiz card.
   */
  note      String?
  createdAt DateTime @default(now())

  memberships           HouseholdMembership[]
  invitationLinks       InvitationLink[]
  categories            Category[]
  projects              Project[]
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]
  budgets               Budget[]
  apiKeys               ApiKey[]
  mailTemplates         HouseholdMailTemplate[]
  csvImports            CsvImport[]
  importLearnings       ImportLearning[]
  notifications         Notification[]
  fixedCosts            FixedCost[]
  accounts              Account[]
  fintsConnections      FintsConnection[]
  standingOrders        StandingOrder[]
}

// FinTS-Foundation (Phase 14a.1):
// Konto-Entität — kapselt Bank-Konten (FinTS-synchronisiert), Bargeld-Töpfe,
// und den Default-CSV-Topf für Bestandsdaten. Alle Transactions hängen
// jetzt zusätzlich an einem Account; Visibility regelt Sichtbarkeit für
// andere Household-Member analog zur Transaction.visibility.
//
// ownerId trägt nur bei type=fints den Besitzer der späteren FintsConnection
// (Spätere Phase 14a.3 ergänzt fintsConnectionId + fintsAccountRef).
model Account {
  id                    String      @id @default(cuid())
  householdId           String
  ownerId               String?
  name                  String
  type                  AccountType
  currency              String      @default("EUR")
  iban                  String?
  bic                   String?
  visibility            Visibility  @default(SHARED)
  archivedAt            DateTime?
  // Whether the FinTS sync loop should fetch statements/balances for this
  // account. true = include (default), false = skip silently. Only meaningful
  // for type=fints; ignored for csv_only/manual.
  syncEnabled           Boolean     @default(true)
  // Phase 14a.3: FinTS-Anbindung
  fintsConnectionId     String?
  /**
   * lib-fints-Sub-Account-ID (interne Bank-Subaccount-Referenz).
   */
  fintsAccountRef       String?
  /**
   * Letzter HKSAL-Saldo-Stand.
   */
  lastKnownBalanceCents Int?
  lastBalanceAt         DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  owner           User?            @relation("AccountOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  fintsConnection FintsConnection? @relation(fields: [fintsConnectionId], references: [id], onDelete: SetNull)
  transactions    Transaction[]
  standingOrders  StandingOrder[]

  @@index([householdId])
  @@index([householdId, type])
  @@index([ownerId])
  @@index([fintsConnectionId])
}

// FinTS-Connection (Phase 14a.3):
// Speichert die Bankverbindung pro User. PIN + lib-fints-Sitzungs-State sind
// AES-256-GCM-verschlüsselt; AAD = connectionId, sodass kein Cipher-Swap
// zwischen Connections möglich ist. Der Master-Key (FINTS_MASTER_KEY) lebt
// nur in FintsCryptoService.
model FintsConnection {
  id                String                @id @default(cuid())
  /**
   * Owner = User, der die Verbindung eingerichtet hat.
   */
  ownerId           String
  /**
   * Household für RLS-Konsistenz.
   */
  householdId       String
  bankName          String
  blz               String
  serverUrl         String
  loginName         String
  /**
   * AES-256-GCM Cipher des Sitzungs-State-Blobs (PIN + lib-fints-State).
   */
  credentialsCipher Bytes
  credentialsIv     Bytes
  credentialsTag    Bytes
  status            FintsConnectionStatus @default(SETUP)
  /**
   * Zeitpunkt der letzten erfolgreichen TAN-Auth.
   */
  lastScaAt         DateTime?
  /**
   * lastScaAt + 89 Tage (PSD2 SCA, konfigurierbar).
   */
  scaExpiresAt      DateTime?
  lastSyncAt        DateTime?
  lastSyncStatus    FintsSyncStatus?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  owner     User           @relation("FintsConnectionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  household Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  accounts  Account[]
  syncRuns  FintsSyncRun[]

  // One connection per (owner, bank, login) — guards the setup wizard
  // against creating duplicates when a setup attempt is retried.
  @@unique([ownerId, blz, loginName])
  @@index([ownerId])
  @@index([householdId])
  @@index([scaExpiresAt])
  @@index([status])
}

// BLZ-Registry (Phase 14a.4):
// Single-Row-Snapshot der hbci4j-Bankenliste. Bei jedem erfolgreichen
// Refresh wird eine neue Zeile angelegt und alte gelöscht. Audit-Trail
// historischer Versionen läuft via AuditLog (changed/added/removed).
model BlzRegistry {
  id           Int      @id @default(autoincrement())
  fetchedAt    DateTime @default(now())
  /**
   * ETag/Commit-SHA aus HTTP-Response — für If-None-Match.
   */
  sourceCommit String?
  sourceUrl    String
  recordCount  Int
  /**
   * BankRecord[] indexed by BLZ als JSON.
   */
  banks        Json
  /**
   * sha256 der Roh-Datei — Änderungs-Detection.
   */
  contentHash  String

  @@index([fetchedAt])
}

// FinTS-Sync-Run (Phase 14a.3):
// Pro Sync-Versuch ein Eintrag. Hält TAN-Challenge solange Status=TAN_REQUIRED;
// nach erfolgreicher TAN-Eingabe wird tanChallenge gelöscht.
model FintsSyncRun {
  id                String           @id @default(cuid())
  connectionId      String
  status            FintsSyncStatus
  triggeredBy       FintsSyncTrigger
  triggeredById     String?
  startedAt         DateTime         @default(now())
  finishedAt        DateTime?
  fromDate          DateTime?
  toDate            DateTime?
  bookingsFetched   Int              @default(0)
  bookingsImported  Int              @default(0)
  bookingsSkipped   Int              @default(0)
  /**
   * Diff zwischen FinTS-HKSAL-Saldo und Summe lokaler TX.
   */
  balanceDriftCents Int?
  /**
   * TAN-Challenge-Payload — { method, prompt, mediaBase64? }. Wird nach Verbrauch gelöscht.
   */
  tanChallenge      Json?
  errorCode         String?
  errorMessage      String?

  connection   FintsConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([connectionId, startedAt])
  @@index([status])
}

model HouseholdMembership {
  id          String        @id @default(cuid())
  userId      String
  householdId String
  role        HouseholdRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@index([householdId])
  @@index([userId])
}

model InvitationLink {
  id              String    @id @default(cuid())
  householdId     String
  token           String    @unique
  email           String?
  createdByUserId String?
  expiresAt       DateTime?
  usedAt          DateTime?
  usedByUserId    String?
  createdAt       DateTime  @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([token])
}

// ─────────────────────────────────────────────
// KATEGORIEN
// ─────────────────────────────────────────────

model Category {
  id          String       @id @default(cuid())
  householdId String
  name        String
  type        CategoryType
  color       String // hex, z.B. "#22c55e"
  icon        String? // Icon-Name aus Zard UI / lucide
  isArchived  Boolean      @default(false)
  sortOrder   Int          @default(0) // für manuelle Sortierung in der Übersicht
  isDefault   Boolean      @default(false) // vom System angelegt beim Haushalt-Setup
  createdAt   DateTime     @default(now())

  household                  Household                   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recurringTransactions      RecurringTransaction[]
  transactions               Transaction[]
  transactionSplits          TransactionSplit[]
  recurringTransactionSplits RecurringTransactionSplit[]
  budgets                    Budget[]
  importLearnings            ImportLearning[]
  standingOrders             StandingOrder[]

  @@index([householdId])
  @@index([householdId, type])
  @@index([householdId, isArchived])
}

// ─────────────────────────────────────────────
// PROJEKTE
// ─────────────────────────────────────────────

model Project {
  id               String        @id @default(cuid())
  householdId      String
  createdByUserId  String? // nullable (Account-Delete)
  name             String
  description      String?
  status           ProjectStatus @default(ACTIVE)
  totalBudgetCents Int? // null = kein Gesamtbudget definiert
  startDate        DateTime?     @db.Date
  endDate          DateTime?     @db.Date
  color            String // hex
  visibility       Visibility    @default(SHARED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  household             Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]

  @@index([householdId])
  @@index([householdId, status])
  @@index([householdId, visibility])
  @@index([createdByUserId])
}

// ─────────────────────────────────────────────
// RECURRING TRANSACTIONS (Fixkosten / Fix-Einnahmen)
// ─────────────────────────────────────────────
// WICHTIG: Werden NICHT in Transaction-Tabelle materialisiert.
// Overview-Endpoints berechnen alles on-the-fly mit toMonthlyEquivalent().
// Festgehalt = RecurringTransaction mit CategoryType=FIXED_INCOME, isVariable=false

model RecurringTransaction {
  id              String             @id @default(cuid())
  householdId     String
  createdByUserId String? // nullable (Account-Delete)
  name            String
  // amountCents: Schätzwert wenn isVariable=true (in Übersicht mit "~" markiert)
  // Vorzeichen: positiv=Einnahme (INCOME/FIXED_INCOME), negativ=Ausgabe (EXPENSE)
  amountCents     Int
  categoryId      String
  projectId       String?
  frequency       RecurringFrequency
  customDays      Int? // nur bei frequency=CUSTOM_DAYS
  // dayOfMonth: 1–31, wird zur Laufzeit via safeDayOfMonth() geclampt
  // z.B. dayOfMonth=31 im Februar → 28/29
  dayOfMonth      Int?
  startDate       DateTime           @db.Date
  endDate         DateTime?          @db.Date // null = läuft unbegrenzt
  visibility      Visibility         @default(SHARED)
  isVariable      Boolean            @default(false)
  note            String?
  color           String? // custom hex color, z.B. "#22c55e"
  icon            String? // iconify key, z.B. "simple-icons:spotify" oder "lucide:home"
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  household    Household                   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category     Category                    @relation(fields: [categoryId], references: [id])
  project      Project?                    @relation(fields: [projectId], references: [id])
  createdBy    User?                       @relation(fields: [createdByUserId], references: [id])
  // Referenz auf ggf. daraus erstellte manuelle Transaktionen (z.B. wenn User Ist-Wert nachträgt)
  transactions Transaction[]
  splits       RecurringTransactionSplit[]

  @@index([householdId])
  @@index([householdId, isActive])
  @@index([householdId, categoryId])
  @@index([householdId, projectId])
  @@index([createdByUserId])
}

// ─────────────────────────────────────────────
// RECURRING SPLITS — Template-level breakdown
// (e.g. "Festgehalt Netto" → "davon Festgehalt Brutto" +
// "davon Ø Provision Brutto") so the Fixkosten overview surfaces
// the same sub-rows as the bundle PageFixkosten.
// ─────────────────────────────────────────────
model RecurringTransactionSplit {
  id                     String  @id @default(cuid())
  recurringTransactionId String
  label                  String
  amountCents            Int
  sortOrder              Int     @default(0)
  categoryId             String?
  note                   String?

  recurringTransaction RecurringTransaction @relation(fields: [recurringTransactionId], references: [id], onDelete: Cascade)
  category             Category?            @relation(fields: [categoryId], references: [id])

  @@index([recurringTransactionId])
}

// ─────────────────────────────────────────────
// STANDING ORDERS (Daueraufträge) — Phase 14b
// Bank-side payment instructions, distinct from RecurringTransaction (budget concept).
// FINTS_DERIVED records are bank-authoritative; bank fields are then read-only.
// ─────────────────────────────────────────────

model StandingOrder {
  id                 String                 @id @default(cuid())
  householdId        String
  accountId          String
  source             StandingOrderSource
  // Stable group key: lowercased counterparty name + signed amountCents
  // (e.g. "edeka markt|-12550"). Idempotency anchor for FinTS-derived sync.
  // For MANUAL records the service prefixes "manual:" + a timestamp suffix
  // so manual + bank groups never collide.
  groupKey           String
  counterpartyName   String?
  counterpartyIban   String?
  amountCents        Int
  currency           String                 @default("EUR")
  frequency          StandingOrderFrequency
  // Last booking date observed (FINTS_DERIVED) or user-set (MANUAL).
  lastSeenAt         DateTime?              @db.Date
  // Heuristic: lastSeenAt + frequency cadence. NULL when frequency=UNKNOWN/CUSTOM.
  nextExpectedAt     DateTime?              @db.Date
  // Optional category mapping the user assigns to make this DA show up in reports.
  categoryId         String?
  note               String?
  isActive           Boolean                @default(true)
  // Underlying booking type the record was derived from (FINTS_DERIVED only).
  // STANDING_ORDER = klassischer Bank-Dauerauftrag; DIRECT_DEBIT = SEPA-Folgelastschrift;
  // NULL for MANUAL records or detection patterns we have not yet surfaced.
  transactionKind    TransactionKind?
  // Raw bank-side booking label (e.g. "FOLGELASTSCHRIFT", "DAUERAUFTRAG") taken
  // from the latest transaction in the group; mirrors Transaction.bookingText
  // semantics. NULL on MANUAL records and on legacy detections.
  bookingText        String?
  // When non-null, bank-fields (counterparty, amount, frequency, nextExpectedAt) are read-only.
  bankFieldsLockedAt DateTime?
  firstSeenAt        DateTime               @default(now())
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])

  @@unique([householdId, accountId, groupKey])
  @@index([householdId, isActive])
  @@index([accountId])
  @@index([householdId, bookingText])
}

// ─────────────────────────────────────────────
// TRANSAKTIONEN (manuelle + ad-hoc Buchungen)
// ─────────────────────────────────────────────
// Variable Eingänge (Provision, Boni, Steuerrückerstattung) werden hier
// mit CategoryType=INCOME eingetragen.
// amountCents: positiv=Einnahme, negativ=Ausgabe

model Transaction {
  id                     String           @id @default(cuid())
  householdId            String
  createdByUserId        String? // nullable (Account-Delete)
  // positiv = Einnahme (INCOME), negativ = Ausgabe (EXPENSE)
  amountCents            Int
  // Wenn die Buchung geplant war und realisiert wurde, hält dieses Feld den
  // ursprünglich geplanten Betrag — Differenz zu amountCents = Abweichung.
  plannedAmountCents     Int?
  // true = nur geplant (zählt nicht in realisierte Cashflow-/Projekt-Summen)
  isPlanned              Boolean          @default(false)
  categoryId             String
  projectId              String?
  date                   DateTime         @db.Date
  description            String?
  visibility             Visibility       @default(SHARED)
  // Referenz wenn Transaktion zu einem Recurring-Eintrag gehört
  // (z.B. wenn User Ist-Wert für variablen Recurring nachträgt)
  recurringTransactionId String?
  externalRef            String? // Sparkasse Endto-End-Ref / Mandatsref / Kundenreferenz / FinTS endToEndId
  externalHash           String? // SHA-256 über (date|amountCents|counterpartyNorm|purposeNorm)
  counterparty           String? // Empfänger/Absender aus CSV/FinTS
  sourceImportId         String? // FK auf CsvImport, Audit-Trail
  // FinTS-Foundation (Phase 14a.7): FK auf den FintsSyncRun, der die
  // Buchung erstmalig importiert hat. Spiegelt sourceImportId für FinTS.
  fintsSyncRunId         String?
  // FinTS-Foundation (Phase 14a.1):
  // accountId — Zuordnung zum Account (Bargeld, CSV-Topf, FinTS-Konto).
  // Backfill-Migration setzt für alle Bestands-Transactions den Default-
  // "Hauptkonto"-Account des Haushalts. Alle neuen Inserts MÜSSEN accountId
  // setzen (typsicher via `account` connect).
  accountId              String
  // source — Herkunft der Buchung. Vorher implizit über sourceImportId
  // (NULL = manuell, gesetzt = CSV); jetzt explizit, weil FinTS hinzukommt.
  source                 TxSource         @default(manual)
  // Phase 14b — kind classifier derived from FinTS bookingType during ingest.
  // NULL allowed for legacy / manual / CSV rows; FinTS rows get a value at insert.
  transactionKind        TransactionKind?
  // Raw FinTS/CAMT bookingText resp. CSV "Buchungstext" column (e.g.
  // "FOLGELASTSCHRIFT", "BARGELDAUSZAHLUNG GA", "GUTSCHRIFT"). Stored
  // verbatim from the bank — UI normalises to title-case for display.
  // NULL for legacy/manual rows where no bank-side label exists.
  bookingText            String?
  // bankFieldsLockedAt — wenn gesetzt, gelten Bank-Felder (amount, date,
  // counterparty, externalRef) als read-only (z. B. bei FinTS-Buchungen).
  // User-Klassifikationen (Kategorie, Projekt, Notiz, Icon, Farbe) bleiben
  // editierbar.
  bankFieldsLockedAt     DateTime?
  // Optionaler per-Buchung-Override (sonst zieht UI Icon/Farbe der Kategorie).
  // Spiegelt RecurringTransaction.color/icon — gleicher Edit-Dialog für beide.
  color                  String? // hex, z.B. "#22c55e"
  icon                   String? // iconify key, z.B. "lucide:shopping-cart"
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  household            Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category             Category              @relation(fields: [categoryId], references: [id])
  project              Project?              @relation(fields: [projectId], references: [id])
  recurringTransaction RecurringTransaction? @relation(fields: [recurringTransactionId], references: [id])
  csvImport            CsvImport?            @relation(fields: [sourceImportId], references: [id])
  fintsSyncRun         FintsSyncRun?         @relation(fields: [fintsSyncRunId], references: [id], onDelete: SetNull)
  splits               TransactionSplit[]
  account              Account               @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([householdId, externalRef])
  @@index([householdId, date])
  @@index([householdId, categoryId])
  @@index([householdId, projectId])
  @@index([householdId, visibility])
  @@index([householdId, isPlanned])
  @@index([householdId, externalHash])
  @@index([sourceImportId])
  @@index([createdByUserId])
  @@index([recurringTransactionId])
  @@index([accountId])
  @@index([accountId, source])
  @@index([fintsSyncRunId])
  @@index([householdId, transactionKind])
  @@index([householdId, bookingText])
}

// ─────────────────────────────────────────────
// TRANSACTION SPLITS
// One booking can be internally split (e.g. salary = base + bonus) so the
// list still renders one row but the breakdown shows under it. Splits are
// always cascade-deleted with the parent and never carry their own
// category/visibility — they inherit from the parent transaction.
// ─────────────────────────────────────────────
model TransactionSplit {
  id            String  @id @default(cuid())
  transactionId String
  /**
   * Display label for the split (e.g. "Festgehalt Brutto").
   */
  label         String
  /**
   * Signed cents — same sign convention as Transaction.amountCents.
   */
  amountCents   Int
  /**
   * Optional sort order within the parent (lower comes first).
   */
  sortOrder     Int     @default(0)
  /**
   * Optional override category — null = inherit parent.category.
   */
  categoryId    String?
  note          String?

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id])

  @@index([transactionId])
}

// ─────────────────────────────────────────────
// CSV IMPORT
// ─────────────────────────────────────────────

model CsvImport {
  id                String   @id @default(cuid())
  householdId       String
  createdByUserId   String
  filename          String
  rowCount          Int
  importedCount     Int      @default(0)
  skippedDuplicates Int      @default(0)
  skippedFixed      Int      @default(0)
  createdRecurrings Int      @default(0)
  createdAt         DateTime @default(now())

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([householdId, createdAt])
}

model ImportLearning {
  id              String   @id @default(cuid())
  householdId     String
  counterpartyKey String // normalisiert: lowercase, ohne Sonderzeichen, max 64 chars
  categoryId      String
  hitCount        Int      @default(1)
  lastUsedAt      DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id])

  @@unique([householdId, counterpartyKey])
  @@index([householdId, lastUsedAt])
}

// ─────────────────────────────────────────────
// BUDGETS
// ─────────────────────────────────────────────

model Budget {
  id          String   @id @default(cuid())
  householdId String
  categoryId  String
  // IMMER als YYYY-MM-01 gespeichert (Monatserster)
  month       DateTime @db.Date
  amountCents Int // Soll-Betrag für den Monat (positiv)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id])

  @@unique([householdId, categoryId, month])
  @@index([householdId, month])
}

// ─────────────────────────────────────────────
// API-KEYS (für Public API)
// ─────────────────────────────────────────────

model ApiKey {
  id              String    @id @default(cuid())
  householdId     String
  createdByUserId String? // nullable (Account-Delete)
  name            String // z.B. "n8n Automation" oder "Home Assistant"
  // Prefix: erste 8 Zeichen nach "bgb_live_", für Anzeige + DB-Lookup
  // Beispiel: vollständiger Key = bgb_live_aBcDeFgH[weitere 24 chars]
  //           prefix = "aBcDeFgH" (für Lookup), hashedSecret = Argon2(rest)
  prefix          String
  hashedSecret    String // Argon2id-Hash des Rest-Tokens
  scopes          String[] // z.B. ["transactions:read", "overview:read"]
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  lastUsedIp      String?
  rateLimitPerMin Int       @default(60)
  isRevoked       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([prefix]) // für schnellen Lookup bei jedem API-Request
  @@index([householdId])
  @@index([isRevoked])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String? // null bei System-Events
  householdId String?
  // Aktions-Format: "resource.action", z.B.:
  // user.login, user.login.failed, user.register, user.delete
  // oidc.login, oidc.link, oidc.unlink
  // apikey.created, apikey.revoked, apikey.used
  // household.created, member.invited, member.joined, member.removed
  // admin.role_changed
  action      String
  metadata    Json? // zusätzliche Kontext-Daten (keine Passwörter!)
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([householdId])
  @@index([action])
  @@index([createdAt])
  // Compound indexes for admin filter+sort queries
  @@index([action, createdAt])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────
// EMAIL LOG (Versandhistorie aller Mails — Admin-only)
// ─────────────────────────────────────────────

enum EmailStatus {
  SENT
  FAILED
}

model EmailLog {
  id          String      @id @default(cuid())
  to          String
  subject     String
  template    String // z.B. "email-verification", "invite", "custom"
  status      EmailStatus
  error       String? // SMTP-Fehlertext bei FAILED
  userId      String? // optional: Empfänger-User (falls bekannt)
  householdId String? // optional: Kontext-Haushalt
  sentAt      DateTime    @default(now())

  @@index([sentAt])
  @@index([status])
  @@index([householdId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// MAIL TEMPLATES (pro Haushalt)
// ─────────────────────────────────────────────

enum MailTemplateType {
  INVITE
  REMINDER
  CUSTOM
  EMAIL_VERIFY
  PASSWORD_RESET
  TOTP_ENABLE
  TOTP_DISABLE
  API_KEY_CREATED
}

// ─────────────────────────────────────────────
// OAUTH 2.1 (für MCP-Endpoint)
// ─────────────────────────────────────────────
// Ausschließlich für den MCP-Endpoint genutzt — JWT-Audience "klar-mcp".
// Die bestehende Klar-Web-Auth (RefreshToken, OidcIdentity) bleibt unberührt.
// API-Keys (ApiKey) bleiben für M2M / Public API.

model OAuthClient {
  id                          String    @id @default(cuid())
  // Public Identifier, im JWT als azp; Pattern "klar_mcp_<24 hex>"
  clientId                    String    @unique
  // Argon2id; null bei public clients (PKCE-only, Standard für MCP-Desktop)
  clientSecretHash            String?
  clientName                  String // Anzeige im Consent-Screen (vom Client bei Registration gesetzt)
  // User-overridable Anzeigename für Connected-Apps-UI. Hilfreich weil
  // generische Proxies (mcp-remote) sich überall als "MCP CLI Proxy" registrieren —
  // User kann das auf "Claude Desktop", "Codex" usw. umbenennen.
  displayName                 String?
  redirectUris                String[] // Whitelist für Authorize/Token
  logoUri                     String?
  clientUri                   String?
  tosUri                      String?
  policyUri                   String?
  // "none" (PKCE-only) | "client_secret_post"
  tokenEndpointAuthMethod     String    @default("none")
  // SHA-256 Hex; ermöglicht spätere RFC 7592 Client-Updates (nicht im MVP)
  registrationAccessTokenHash String?
  // Sicherheits-Bremse: ab > 100 fehlgeschlagene Token-Requests in 24h auto-disable
  failedTokenRequests24h      Int       @default(0)
  failedTokenWindowStart      DateTime?
  disabled                    Boolean   @default(false)
  createdAt                   DateTime  @default(now())

  authCodes OAuthAuthCode[]
  grants    OAuthGrant[]
  consents  OAuthConsent[]

  @@index([clientId])
}

// Kurzlebig: Authorization Code (TTL 60s, single-use).
// Speichert SHA-256 vom ausgegebenen Code als Primärschlüssel.
model OAuthAuthCode {
  // SHA-256 hex(plain code) — nie Plain speichern
  code                String    @id
  clientId            String
  userId              String
  householdId         String
  scopes              String[]
  redirectUri         String
  // PKCE: Base64URL-encoded SHA-256 vom code_verifier
  codeChallenge       String
  // Pflicht "S256" (verifyAuthorize lehnt "plain" ab)
  codeChallengeMethod String
  expiresAt           DateTime
  // Single-use Lock — gesetzt beim ersten Token-Exchange.
  // Replay → Cascade-Revoke aller Grants des Clients (Phase 6).
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
}

// Persistente Grant-Verbindung User ↔ Client.
// Refresh-Token rotating: jede Refresh-Anfrage erzeugt neuen Grant, alter wird revoked.
model OAuthGrant {
  id               String    @id @default(cuid())
  clientId         String
  userId           String
  householdId      String
  scopes           String[]
  // SHA-256 hex vom Refresh-Token-Plaintext "klar_rt_<...>"
  refreshTokenHash String    @unique
  refreshExpiresAt DateTime
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, clientId])
  @@index([refreshExpiresAt])
}

// User-Consent pro Client. Subset-Match → Auto-Approve im Authorize-Flow.
// Bei zusätzlich angeforderten Scopes wird der Consent-Screen erneut gezeigt.
model OAuthConsent {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  scopes    String[]
  grantedAt DateTime @default(now())

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId])
  @@index([clientId])
}

model HouseholdMailTemplate {
  id           String           @id @default(cuid())
  householdId  String
  templateType MailTemplateType
  name         String // Anzeigename, z.B. "Einladung an Nachbar"
  subject      String // E-Mail-Betreff mit Handlebars-Platzhaltern
  body         String // HTML-Body mit Handlebars-Platzhaltern
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, templateType])
  @@index([householdId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────
// Notification-Center + Bell. userId=null → household-wide.
// Trigger via NotificationsService.enqueue(ctx, kind, ...).
model Notification {
  id          String           @id @default(cuid())
  householdId String
  userId      String? // null = household-wide
  kind        NotificationKind
  title       String
  body        String?
  payloadJson Json?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId, userId, readAt])
  @@index([householdId, createdAt])
}

// ─────────────────────────────────────────────
// FIXED COSTS (auto-detected recurring expenses/income from real bookings)
// ─────────────────────────────────────────────
// FixedCost is the BASE concept: anything the detection algorithm finds as a
// recurring booking pattern across CSV+FinTS transactions.
// Pure detection lives in packages/shared/src/detection/ — same algorithm runs
// after CSV imports, after FinTS sync, and on the manual /recompute endpoint.
//
// Contract (below) is a 1:1 EXTENSION of FixedCost for things the user wants
// to track as a real contract (with cancellation deadline, holder, contract
// number, etc.). Every Contract IS a FixedCost; not every FixedCost is a
// Contract — many are just "I pay this every month" without contract paperwork.
//
// confidence ∈ [0,1] from the heuristic (repetition + amount stability).
// detectedFromTransactionIds: audit trail of which Transactions matched.
// source: AUTO_DETECTED (algorithm) or USER_DEFINED (user typed it manually).
model FixedCost {
  id                         String          @id @default(cuid())
  householdId                String
  name                       String
  merchant                   String? // normalized merchant key (auto-detected) or display label
  categoryId                 String?
  amountCents                Int
  cycle                      FixedCostCycle
  nextRenewalAt              DateTime?       @db.Date
  confidence                 Float           @default(0)
  status                     FixedCostStatus @default(CANDIDATE)
  source                     FixedCostSource @default(AUTO_DETECTED)
  detectedFromTransactionIds String[]        @default([])
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  contract  Contract?

  @@index([householdId, status])
  @@index([householdId, nextRenewalAt])
  @@index([householdId, source])
}

enum FixedCostSource {
  AUTO_DETECTED // produced by the detection algorithm
  USER_DEFINED // user typed it in manually
}

// 1:1 extension on FixedCost. Created when the user promotes a FixedCost
// to a real contract (e.g. for cancellation tracking).
model Contract {
  id                String    @id @default(cuid())
  fixedCostId       String    @unique
  cancelByAt        DateTime? @db.Date
  contractStartedAt DateTime? @db.Date
  contractHolder    String?
  contractNumber    String?
  providerName      String?
  documentUrl       String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  fixedCost FixedCost @relation(fields: [fixedCostId], references: [id], onDelete: Cascade)

  @@index([cancelByAt])
}

// ─────────────────────────────────────────────
// CONNECTED APPS (Settings → Connected Apps)
// ─────────────────────────────────────────────
// Generic per-user link to external identity / integration providers.
// Distinct from ApiKey (M2M tokens) and OidcIdentity (login-only).
model ConnectedApp {
  id         String    @id @default(cuid())
  userId     String
  provider   String // pocketid | github | google | claude_ai | …
  externalId String
  scopes     String[]  @default([])
  linkedAt   DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, externalId])
  @@index([userId])
}
