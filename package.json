{
  "name": "klar",
  "version": "1.19.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @klar/api dev",
    "dev:web": "pnpm --filter @klar/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "pnpm --filter @klar/api test:integration",
    "test:e2e": "pnpm --filter @klar/api test:e2e",
    "clean": "turbo run clean && rimraf node_modules",
    "db:migrate": "pnpm --filter @klar/api prisma:migrate",
    "db:seed": "pnpm --filter @klar/api prisma:seed",
    "db:reset": "pnpm --filter @klar/api prisma:reset",
    "db:studio": "pnpm --filter @klar/api prisma:studio",
    "docker:up": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.dev.yml logs -f"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.0",
    "semantic-release": "^24.0.0",
    "turbo": "latest",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.9.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "prisma",
      "@swc/core"
    ],
    "overrides": {
      "fastify": "^5.8.5"
    }
  }
}
