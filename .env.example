# Copy to .env and fill in values

# ─── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://klar:klar@localhost:5432/klar
DATABASE_TEST_URL=postgresql://klar:klar@localhost:5432/klar_test

# ─── JWT RS256 Key Pair (generate with: pnpm --filter @klar/api keys:generate)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_LONG=30d

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
REGISTRATION_ENABLED=true
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200

# ─── Mail (Dev: MailDev via docker-compose.dev.yml, Web-UI: http://localhost:1080)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_FROM=noreply@klar.app
MAIL_FROM_NAME=Klar
