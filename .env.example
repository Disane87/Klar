# Copy to .env and fill in values

# ─── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://klar:klar@localhost:5432/klar
DATABASE_TEST_URL=postgresql://klar:klar@localhost:5432/klar_test

# ─── JWT RS256 Key Pair (generate with: pnpm --filter @klar/api keys:generate)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_LONG=30d

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
REGISTRATION_ENABLED=true
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200

# ─── Mail ─────────────────────────────────────────────────────────────────────
# Dev:  MailDev läuft via docker-compose.dev.yml, Web-UI: http://localhost:1080
# Prod: SMTP-Zugangsdaten deines Providers (z.B. Resend, Postmark, eigener SMTP)
#
# MAIL_SECURE=true  → Port 465  (SMTPS, direkt TLS)
# MAIL_SECURE=false → Port 587  (STARTTLS) oder 1025 (MailDev, kein Auth)
# MAIL_USER / MAIL_PASS leer lassen für MailDev (keine Authentifizierung nötig)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@klar.app
MAIL_FROM_NAME=Klar

# ─── OIDC / SSO (optional) ────────────────────────────────────────────────────
# Auf true setzen um OIDC-Login zu aktivieren (z.B. PocketID, Authentik, Keycloak)
OIDC_ENABLED=false
# Anzeigename des Providers (erscheint auf dem Login-Button)
OIDC_PROVIDER_NAME=sso
# Issuer-URL deines OIDC-Providers (z.B. https://pocketid.example.com)
OIDC_ISSUER_URL=
# Client-ID und Secret aus der OIDC-Provider-Konfiguration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Callback-URL — muss im OIDC-Provider als Redirect URI eingetragen sein
OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/oidc/callback
# Scopes (Leerzeichen-getrennt) — openid, email und profile werden empfohlen
OIDC_SCOPES=openid email profile
# Optional: Nur Mitglieder dieser Gruppe dürfen sich einloggen
OIDC_REQUIRED_GROUP=
# Optional: Mitglieder dieser Gruppe erhalten automatisch die App-Admin-Rolle
OIDC_ADMIN_GROUP=
# Optional: Neue OIDC-Nutzer werden automatisch diesem Haushalt beigetreten
OIDC_AUTO_JOIN_HOUSEHOLD_ID=

# ─── FinTS / HBCI (Bank-Sync) ─────────────────────────────────────────────────
# Master-Key zum Verschlüsseln gespeicherter Bank-Credentials (PIN/TAN).
# Pflicht — Container startet sonst nicht. Generieren mit:
#   openssl rand -hex 32
FINTS_MASTER_KEY=

# ZKA-Produktregistrierungs-ID. Sparkasse, Volksbank und viele andere lehnen
# unregistrierte IDs mit Bank-Code 9078 ab. Für eine Produktiv-Instanz unter
# https://www.hbci-zka.de/register/prod_register.htm eine eigene ID beantragen
# und hier eintragen. Default `klar-dev` reicht für Banken ohne strikte Prüfung
# (z.B. einige Direktbanken), funktioniert aber NICHT mit Sparkasse/VR-Banken.
FINTS_PRODUCT_ID=klar-dev

# Strong-Customer-Authentication-Fenster in Tagen (PSD2 vorgibt max. 90).
# Innerhalb dieses Zeitraums darf ohne erneute TAN synchronisiert werden.
FINTS_SCA_WINDOW_DAYS=89

# BLZ-Verzeichnis (Bankleitzahlen → HBCI-Endpoints). Wird beim Sync gecached.
FINTS_BLZ_SOURCES=https://raw.githubusercontent.com/hbci4j/hbci4java/master/src/main/resources/blz.properties
